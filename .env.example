# ---------- Sanity CMS (Next.js app) ----------
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
# Server-side read token (NEVER commit). Use a Viewer-role token.
SANITY_API_TOKEN=your_read_only_token

# ---------- Sanity Studio (standalone dev server) ----------
# These only matter for `npm run studio`. Duplicate the values above.
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# ---------- Google Analytics ----------
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ---------- Resend (contact form emails) ----------
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL_FROM=noreply@notify.superguardian.com.au

# ---------- Google reCAPTCHA v3 ----------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ---------- Site URL (used by metadata, Origin check, robots.txt) ----------
NEXT_PUBLIC_SITE_URL=https://www.superguardian.com.au
# Optional extra origins allowed to submit to /api/* (comma-separated),
# e.g. staging hostnames. Leave unset in production.
# ALLOWED_ORIGINS=https://staging.superguardian.com.au

# ---------- Upstash Redis (durable rate limiting — optional) ----------
# When set, /api/* form routes use Upstash for per-IP rate limits so the
# limit holds across serverless instances. If unset, the code falls back
# to a best-effort in-memory limiter.
# UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=<rest-token>
