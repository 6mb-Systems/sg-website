# Sanity Configuration (Next.js)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_read_token

# Sanity Studio standalone dev server (must duplicate the values above)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production

# Google Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend - Contact Form
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL_TO=mayinxing@gmail.com
CONTACT_EMAIL_FROM=noreply@notify.superguardian.com.au

# Google reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# Site URL (for metadata)
NEXT_PUBLIC_SITE_URL=https://www.superguardian.com.au
